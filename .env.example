# Copy to .env and adjust for your Pi and network.
TZ=Europe/Stockholm

# Base images / upstream refs
FRIGATE_IMAGE=ghcr.io/blakeblackshear/frigate:0.17.0
VLM_REPO=https://github.com/mikehailodev/hailo-vlm-addon.git
VLM_REF=main
HAILORT_VERSION=5.3.0
HAILORT_DEB=hailort_5.3.0_arm64.deb
FRIGATE_HAILORT_WHEEL=hailort-5.3.0-cp311-cp311-linux_aarch64.whl
VLM_HAILORT_WHEEL=hailort-5.3.0-cp313-cp313-linux_aarch64.whl

# Devices
HAILO_DEVICE=/dev/h1x-0
# Group IDs differ by distro; check with: getent group video render
VIDEO_GROUP_ID=44
RENDER_GROUP_ID=109

# Ports
FRIGATE_WEB_PORT=5000
FRIGATE_AUTH_PORT=8971
FRIGATE_RTSP_PORT=8554
FRIGATE_WEBRTC_TCP_PORT=8555
FRIGATE_WEBRTC_UDP_PORT=8555
GO2RTC_API_PORT=1984
VLM_PORT=8099

# Frigate runtime
FRIGATE_SHM_SIZE=256mb
FRIGATE_CAMERA_RTSP_URL=rtsp://<url-encoded-user>:<url-encoded-password>@<camera-ip>:554/<stream>
